# Cursor ignore — controls what Agent / Tab / @ mentions can access.
# .gitignore entries and Cursor defaults (node_modules, lock files, etc.) also apply.

# --- Secrets ---
.env
.env.*
!.env.example
*.pem

# --- Build & deploy artifacts ---
.next/
out/
build/
.vercel/

# --- Dependencies ---
node_modules/
.pnp
.pnp.js

# --- Lock files (large, low signal for AI) ---
pnpm-lock.yaml
package-lock.json
yarn.lock

# --- Generated ---
next-env.d.ts
*.tsbuildinfo

# --- Test output ---
coverage/

# --- Logs & debug ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS ---
.DS_Store
